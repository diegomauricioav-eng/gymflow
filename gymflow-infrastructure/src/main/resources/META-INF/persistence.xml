<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="gymflowPU" transaction-type="JTA">
        <jta-data-source>jdbc/gymflowDS</jta-data-source>

        <class>co.ufps.gymflow.persistencia.miembro.MiembroJpa</class>
        <class>co.ufps.gymflow.persistencia.plan.PlanJpa</class>
        <class>co.ufps.gymflow.persistencia.membresia.MembresiaJpa</class>

        <properties>
            <!-- Muestra el SQL generado en consola — útil para depurar -->
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
        </properties>
    </persistence-unit>
</persistence>